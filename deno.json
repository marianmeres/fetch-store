{
	"name": "@marianmeres/fetch-store",
	"version": "3.0.3",
	"exports": "./src/mod.ts",
	"tasks": {
		"test": "deno test --watch",
		"npm:build": "deno run -A scripts/build-npm.ts",
		"npm:publish": "deno run -A scripts/build-npm.ts && cd ./.npm-dist && npm publish --access=public"
	},
	"imports": {
		"@marianmeres/pubsub": "jsr:@marianmeres/pubsub@^2.4.5",
		"@marianmeres/store": "jsr:@marianmeres/store@^2.4.3",
		"@std/assert": "jsr:@std/assert@^1.0.17",
		"@std/fs": "jsr:@std/fs@^1.0.22",
		"@std/path": "jsr:@std/path@^1.1.4"
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 90,
		"indentWidth": 4
	},
	"lint": {
		"rules": {
			"exclude": ["no-explicit-any"]
		}
	}
}
